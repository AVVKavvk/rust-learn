  "query": "\n            UPDATE users\n            SET\n                name       = COALESCE($2, name),\n                email      = COALESCE($3, email),\n                bio        = COALESCE($4, bio),\n                updated_at = NOW()\n            WHERE id = $1\n            RETURNING id, name, email, bio, created_at, updated_at\n            ",
